# =========================
# Multi-level common ignores
# =========================

# OS
.DS_Store
Thumbs.db
Desktop.ini

# VSCode
.vscode/
.history/

# Logs
*.log
logs/
**/logs/

# Env
.env
.env.*
!.env.example
!.env.template
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# =========================
# Java / Spring Boot
# =========================
target/
**/target/

build/
**/build/

.gradle/
**/.gradle/

*.class
*.jar
*.war
*.ear

# Spring local config
application-local.yml
application-local.yaml
application-local.properties
application-dev.yml
application-dev.yaml
application-dev.properties
**/application-local.yml
**/application-local.yaml
**/application-local.properties
**/application-dev.yml
**/application-dev.yaml
**/application-dev.properties

# =========================
