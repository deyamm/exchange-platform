**/.pytest_cache/

.mypy_cache/
**/.mypy_cache/

.ruff_cache/
**/.ruff_cache/

.pyright/
**/.pyright/

.coverage
.coverage.*
htmlcov/
**/htmlcov/

*.egg-info/
**/*.egg-info/

